# Service config
CONSOLE_WEB_URL=                        # [필수] Dify 콘솔 URL (예: https://dify.example.com)
SECRET_KEY=                             # [필수] Dify의 SECRET_KEY와 반드시 동일해야 함 (JWT 서명 공유)
TENANT_ID=                              # [필수] Dify 워크스페이스 ID. SSO 로그인 시 사용자를 이 워크스페이스에 소속시킴
                                        #        확인: SELECT id FROM tenants LIMIT 1;
EDITION=SELF_HOSTED                     # [선택] 기본값: SELF_HOSTED
ACCOUNT_DEFAULT_ROLE=editor             # [선택] SSO 신규 사용자 기본 역할 (admin/editor/normal/dataset_operator), 기본값: normal
INTERNAL_API_KEY=                       # [필수] 내부 서버 간 호출용 API 키. openssl rand -hex 32 로 생성
DIFY_WEB_INTERNAL_URL=                  # [선택] Dify 웹 프론트엔드 내부 URL (ALB 사용 시 /chat/ 임베드 프록시에 필요)
                                        #        예: http://opencode-web-dev:3000
EMBED_ALLOWED_ORIGINS=                  # [선택] 비인증 임베드를 허용할 외부 Origin 목록 (쉼표 구분)
                                        #        예: https://external.com,https://customer.com
                                        #        앱별로는 set_app_access_mode API의 embedAllowedOrigins 필드로 설정 가능

# Token config
ACCESS_TOKEN_EXPIRE_MINUTES=900         # [선택] 액세스 토큰 만료 (분), 기본값: 900 (15시간)
REFRESH_TOKEN_EXPIRE_DAYS=30            # [선택] 리프레시 토큰 만료 (일), 기본값: 30
REFRESH_TOKEN_PREFIX=refresh_token:     # [선택] 기본값: refresh_token:
ACCOUNT_REFRESH_TOKEN_PREFIX=account_refresh_token:  # [선택] 기본값: account_refresh_token:

# OIDC config (Authelia)
OIDC_CLIENT_ID=                         # [필수] Authelia에 등록한 client_id
# Generate OIDC plaintext secret (32 chars recommended for examples):
#
# [Windows PowerShell] 16 random bytes -> 32-char hex
#   $b = New-Object byte[] 16; [System.Security.Cryptography.RandomNumberGenerator]::Fill($b); ([System.BitConverter]::ToString($b)).Replace('-','').ToLower()
#
# [Linux/macOS] 16 random bytes -> 32-char hex
#   openssl rand -hex 16
OIDC_CLIENT_SECRET=                     # [필수] 위 명령어로 32자 평문 시크릿 (Authelia에는 argon2id 해시값 입력)
OIDC_DISCOVERY_URL=                     # [필수] OIDC Discovery URL (예: https://dify.example.com/auth/.well-known/openid-configuration)
OIDC_REDIRECT_URI=                      # [필수] 콜백 URL (예: https://dify.example.com/console/api/enterprise/sso/oidc/callback)
OIDC_SCOPE=openid profile email         # [선택] 기본값: openid profile email roles
OIDC_RESPONSE_TYPE=code                 # [선택] 기본값: code

# Database (Dify와 동일한 PostgreSQL)
DB_USERNAME=                            # [필수]
DB_PASSWORD=                            # [필수]
DB_HOST=127.0.0.1                       # [필수]
DB_PORT=5432                            # [선택] 기본값: 5432
DB_DATABASE=dify                        # [선택] 기본값: dify

# Redis (Dify와 동일한 Redis)
REDIS_HOST=127.0.0.1                    # [필수]
REDIS_PORT=6379                         # [선택] 기본값: 6379
REDIS_DB=0                              # [선택] 기본값: 0
REDIS_PASSWORD=                         # [선택] 비밀번호 없으면 비워둠
